{
  "name": "Custom Theme",
  "dataColors": [
    "#93eee8",
    "#36d9fc",
    "#024ac8",
    "#22c2fc",
    "#27a3e9"
  ],
  "foreground": "#111827",
  "background": "#f4fdfd",
  "foregroundNeutralSecondary": "#6b7280",
  "backgroundLight": "#e9fcfa",
  "foregroundNeutralTertiary": "#6b7280",
  "backgroundNeutral": "#fafefe",
  "tableAccent": "#93eee8",
  "maximum": "#024ac8",
  "center": "#36d9fc",
  "minimum": "#93eee8",
  "bad": "#93eee8",
  "neutral": "#36d9fc",
  "good": "#024ac8",
  "textClasses": {
    "callout": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#fafefe"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#fafefe"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#fafefe"
              }
            },
            "border": {
              "solid": {
                "color": "#fafefe"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#e9fcfa"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#f4fdfd"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}