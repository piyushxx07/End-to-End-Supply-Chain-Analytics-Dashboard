{
  "name": "Custom Theme",
  "dataColors": [
    "#0e321a",
    "#6f2bec",
    "#b5c5f8",
    "#4b5f9a",
    "#303c79"
  ],
  "foreground": "#111827",
  "background": "#e7ebe8",
  "foregroundNeutralSecondary": "#6b7280",
  "backgroundLight": "#b1b9b3",
  "foregroundNeutralTertiary": "#6b7280",
  "backgroundNeutral": "#ffffff",
  "tableAccent": "#0e321a",
  "maximum": "#b5c5f8",
  "center": "#6f2bec",
  "minimum": "#0e321a",
  "bad": "#0e321a",
  "neutral": "#6f2bec",
  "good": "#b5c5f8",
  "textClasses": {
    "callout": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#ffffff"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "border": {
              "solid": {
                "color": "#ffffff"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#b1b9b3"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#e7ebe8"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}