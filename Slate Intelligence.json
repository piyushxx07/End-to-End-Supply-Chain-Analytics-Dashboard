{
  "name": "Slate Intelligence",
  "dataColors": [
    "#1E293B",
    "#334155",
    "#475569",
    "#64748B",
    "#94A3B8"
  ],
  "foreground": "#050505",
  "background": "#E2E8F0",
  "foregroundNeutralSecondary": "#808080",
  "backgroundLight": "#CBD5E1",
  "foregroundNeutralTertiary": "#808080",
  "backgroundNeutral": "#F1F5F9",
  "tableAccent": "#1E293B",
  "maximum": "#475569",
  "center": "#334155",
  "minimum": "#1E293B",
  "bad": "#1E293B",
  "neutral": "#334155",
  "good": "#475569",
  "textClasses": {
    "callout": {
      "color": "#050505",
      "fontFace": "'Segoe UI', sans-serif"
    },
    "title": {
      "color": "#050505",
      "fontFace": "'Segoe UI', sans-serif"
    },
    "header": {
      "color": "#050505",
      "fontFace": "'Segoe UI', sans-serif"
    },
    "label": {
      "color": "#050505",
      "fontFace": "'Segoe UI', sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F1F5F9"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#F1F5F9"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#F1F5F9"
              }
            },
            "border": {
              "solid": {
                "color": "#F1F5F9"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#CBD5E1"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}